# Copy this file to .env (already gitignored) and fill in real values.
# stateguard's CLI loads .env automatically from the current working directory —
# see src/stateguard/cli.py's _load_dotenv(). A real shell `export` always wins over
# whatever is in this file.

# Required for `stateguard ai-review` / the ai-review stage of `run-cycle`.
# Without it, that stage is skipped: "SKIPPED: DEEPSEEK_API_KEY not set".
DEEPSEEK_API_KEY=

# Optional — defaults shown below (src/stateguard/ai_review.py).
# DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions
# DEEPSEEK_MODEL=deepseek-chat
