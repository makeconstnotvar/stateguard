# Copy to infra/.env, chmod 600 infra/.env, and replace all secrets.
SONARQUBE_IMAGE=sonarqube:26.7.0.124771-community
SONAR_DB_IMAGE=postgres:17
SONAR_DB_NAME=sonar
SONAR_DB_USER=sonar
SONAR_DB_PASSWORD=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET
SONAR_BIND_ADDRESS=127.0.0.1
SONAR_PORT=9000

# Start small. Measure heap, background-task latency and DB load before increasing.
SONAR_WEB_JAVAOPTS=-Xms512m -Xmx512m
SONAR_CE_JAVAOPTS=-Xms512m -Xmx1024m
SONAR_SEARCH_JAVAOPTS=-Xms1g -Xmx1g
